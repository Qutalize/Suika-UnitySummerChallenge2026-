# ==== Unity generated ====
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
/[Mm]emoryCaptures/
/[Rr]ecordings/

# Asset meta data should only be ignored when the corresponding asset is also ignored
!/[Aa]ssets/**/*.meta

# Autogenerated project files (regenerated by Unity)
/[Aa]ssembly-CSharp*.csproj
/*.sln
/*.csproj
.vsconfig

# Visual Studio / Rider / VS Code
.vs/
.idea/
.vscode/
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.suo

# Recovery / backup
/[Aa]ssets/_Recovery/

# Claude Code local settings (personal)
.claude/settings.local.json

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Large media (record locally, don't commit)
*.mp4
*.mov
*.avi

# Crash / build reports
sysinfo.txt
*.stackdump
crashlog.txt

# ==== リポジトリに含めない素材（自作でない／配布対象外）====
# Seaeees様のペンギンモデル（改変版・再配布不可）。ディスクには残す
[Aa]ssets/**/penguin_slim*.fbx
[Aa]ssets/**/penguin_slim*.fbx.meta
# YGS Beach Party & Fun Pack（第三者アセット・再配布不可）
[Aa]ssets/YGS Beach Party & Fun Pack/
[Aa]ssets/YGS Beach Party & Fun Pack.meta
